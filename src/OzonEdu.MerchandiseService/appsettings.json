{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.ndjson",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Telemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Kafka": {
    "Enabled": true,
    "BootstrapServers": "localhost:9092",
    "PollTimeoutMs": 1000,
    "OutboxBatchSize": 20,
    "Topics": {
      "StockReplenishedEvent": "stock_replenished_event",
      "EmployeeNotificationEvent": "employee_notification_event",
      "EmailNotificationEvent": "email_notification_event"
    },
    "ConsumerGroups": {
      "StockReplenished": "merchandise-service-stock-replenished",
      "EmployeeNotification": "merchandise-service-employee-notification"
    }
  },
  "DatabaseConnectionOptions": {
    "ConnectionString": "Host=localhost;Port=5436;Database=merchandise-services;Username=postgres;Password=merchandiseServicesPassword"
  },
  "StockApiGrpcServiceConfiguration": {
    "ServerAddress": "http://localhost:5072"
  }
}
